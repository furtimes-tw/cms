# Payload secret
# Generate a strong random string before production.
PAYLOAD_SECRET=replace-with-a-long-random-secret

# Public server URL of the CMS
# Local development:
# NEXT_PUBLIC_SERVER_URL=http://localhost:3001
# Production:
# NEXT_PUBLIC_SERVER_URL=https://cms.furtimes.tw
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Database
# Current local SQLite development example:
DATABASE_URL=file:./furtimes.db

# Future PostgreSQL production example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Optional: frontend URL, useful for CORS / preview / later integrations
FRONTEND_URL=http://localhost:3000

# S3 settings for media storage (optional, defaults to local storage)
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=
